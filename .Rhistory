satisfaction_p ~ int*1
# Residual variances
satisfaction_a ~~ var*satisfaction_a
satisfaction_p ~~ var*satisfaction_p
# Predictor variances and covariances
wnc_a ~~ wnc_p
recovery_a ~~ recovery_p
'
