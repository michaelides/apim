library(tibble)
library(interactions)
load("data/exercise_data.RData")
cat("Long format (ddl2):", nrow(ddl2), "rows,", ncol(ddl2), "columns\n")
cat("Wide format (ddw2):", nrow(ddw2), "rows,", ncol(ddw2), "columns\n\n")
str(ddl2)
str(ddw2)
icc <- function(model, grp_id = "dyad_id") {
var_components <- as.data.frame(lme4::VarCorr(model))
var_between  <- var_components$vcov[var_components$grp == grp_id]
var_residual <- var_components$vcov[var_components$grp == "Residual"]
if (length(var_between) == 0) {
stop(paste("Grouping factor '", grp_id,
"' not found in the model components.", sep = ""))
}
icc_val <- var_between / (var_between + var_residual)
cat("\n--- Intra-class Correlation (ICC) ---\n")
cat("Between-group variance (", grp_id, "): ",
round(var_between, 4), "\n", sep = "")
cat("Residual variance:", round(var_residual, 4), "\n")
cat("ICC:", round(icc_val, 4), "\n")
cat("Interpretation:", round(icc_val * 100, 1),
"% of variance is shared within groups.\n\n")
return(invisible(icc_val))
}
cat("=== Null models for ICC ===\n\n")
null_eng <- lmer(engagement ~ 1 + (1 | dyad_id), data = ddl2)
summary(null_eng)
icc(null_eng)
null_perf <- lmer(performance ~ 1 + (1 | dyad_id), data = ddl2)
summary(null_perf)
icc(null_perf)
null_creat <- lmer(creativity ~ 1 + (1 | dyad_id), data = ddl2)
summary(null_creat)
icc(null_creat)
cat("=== Dyad-level moderator summaries ===\n\n")
cat("live_together distribution:\n")
print(table(ddl2$live_together))
cat("Proportion:", mean(ddl2$live_together), "\n\n")
cat("years_together:\n")
print(summary(ddl2$years_together))
cat("\ntime_spent_this_morning_together:\n")
print(summary(ddl2$time_spent_this_morning_together))
cat("\n=== Within-dyad predictor correlations ===\n\n")
male_vals <- ddl2 %>% filter(gender == "male")
female_vals <- ddl2 %>% filter(gender == "female")
cor_affect <- cor(male_vals$affect, female_vals$affect)
cor_sdt    <- cor(male_vals$sdt, female_vals$sdt)
cor_jc     <- cor(male_vals$job_crafting, female_vals$job_crafting)
cat("\n=== Paired t-tests (gender mean differences) ===\n\n")
outcomes   <- c("engagement", "performance", "creativity")
predictors <- c("affect", "sdt", "job_crafting")
all_vars   <- c(outcomes, predictors)
for (v in all_vars) {
m_val <- male_vals[[v]]
f_val <- female_vals[[v]]
tt    <- t.test(m_val, f_val, paired = TRUE)
cat(v, ": t =", round(tt$statistic, 3),
", p =", format.pval(tt$p.value, digits = 3), "\n")
}
male_vals
cat("\n========== Section 2: Indistinguishable MLM ==========\n\n")
# --- Engagement ---
apim_eng <- lmer(
engagement ~ affect + sdt + job_crafting +
partner_affect + partner_sdt + partner_job_crafting +
live_together + years_together + time_spent_this_morning_together +
(1 | dyad_id),
data = ddl2
)
actor_only_eng <- lmer(
engagement ~ affect + sdt + job_crafting +
live_together + years_together + time_spent_this_morning_together +
(1 | dyad_id),
data = ddl2
)
cat("--- Engagement APIM ---\n")
summary(apim_eng)
cat("\nLikelihood Ratio Test (partner effects):\n")
anova(actor_only_eng, apim_eng)
names(ddl)
